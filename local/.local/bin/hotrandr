#!/usr/bin/env python3
"""Listen for monitor hotplug and lid events, then run a script."""

import argparse
import logging
import subprocess
import os
import sys
import threading

import evdev
from evdev import ecodes
import pyudev

logging.basicConfig(
    format="%(asctime)s [%(levelname)s] %(message)s",
    datefmt="%H:%M:%S",
    level=logging.INFO,
)
log = logging.getLogger(__name__)

HOTPLUG_ACTIONS = frozenset({"change", "add", "remove"})
DEFAULT_SCRIPT = "handle_monitor_hotplug"


def _run_script(script: str, kind: str, detail: str) -> None:
    log.info("[%s] %s", kind, detail)
    result = subprocess.run([script], check=False)
    if result.returncode != 0:
        log.warning("'%s' exited with code %d", script, result.returncode)


def _listen_udev(script: str) -> None:
    """Watch DRM subsystem for monitor hotplug via udev."""
    context = pyudev.Context()
    monitor = pyudev.Monitor.from_netlink(context)
    monitor.filter_by(subsystem="drm")

    for device in iter(monitor.poll, None):
        if device.action in HOTPLUG_ACTIONS:
            _run_script(script, f"display/{device.action}", device.device_path)


def _listen_resume(script: str) -> None:
    """Re-run script on resume via logind's PrepareForSleep D-Bus signal."""
    try:
        proc = subprocess.Popen(
            [
                "dbus-monitor",
                "--system",
                "type='signal',"
                "interface='org.freedesktop.login1.Manager',"
                "member='PrepareForSleep'",
            ],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except FileNotFoundError:
        log.warning("dbus-monitor not found, resume events will not be detected")
        return

    for line in proc.stdout:
        if "boolean false" in line:
            _run_script(script, "resume", "system woke from sleep")


def _find_lid_switch() -> evdev.InputDevice | None:
    for path in evdev.list_devices():
        device = evdev.InputDevice(path)
        caps = device.capabilities()
        if ecodes.EV_SW in caps and ecodes.SW_LID in caps[ecodes.EV_SW]:
            return device
    return None


def _listen_lid(script: str) -> None:
    """Watch for lid open/close events via evdev."""
    device = _find_lid_switch()
    if device is None:
        log.warning("No lid switch found, lid events will not be detected")
        return

    log.info("Watching lid switch on %s (%s)", device.path, device.name)
    for event in device.read_loop():
        if event.type == ecodes.EV_SW and event.code == ecodes.SW_LID:
            state = "closed" if event.value else "opened"
            _run_script(script, f"lid/{state}", device.path)


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Run a script on monitor hotplug and lid events."
    )
    parser.add_argument(
        "script",
        nargs="?",
        default=DEFAULT_SCRIPT,
        help="Script to run (default: %(default)s)",
    )
    args = parser.parse_args()

    _run_script(args.script, "startup", "initial run")

    log.info(
        "Listening for display/lid/resume events (running '%s' on change)…", args.script
    )
    for target in (_listen_lid, _listen_resume):
        threading.Thread(target=target, args=(args.script,), daemon=True).start()
    _listen_udev(args.script)


if __name__ == "__main__":
    if not os.environ.get("DISPLAY"):
        sys.exit("No DISPLAY, exiting")
    main()
