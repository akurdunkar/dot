#!/usr/bin/env python3
# pylint: disable=too-many-lines

from __future__ import annotations

import argparse
import concurrent.futures
import json
import os
import subprocess
import sys
import tempfile
import threading
from collections import deque
from dataclasses import dataclass, field
from datetime import datetime, timezone
from pathlib import Path
from typing import (
    IO,
    Any,
    Callable,
    Final,
    Iterable,
    Protocol,
    TypedDict,
    cast,
)

import jsonschema
import requests
from colored import attr, fg
from github import Auth, Github, UnknownObjectException
from github.Repository import Repository
from rich.console import Console
from rich.live import Live
from rich.spinner import Spinner
from rich.table import Table
from rich.text import Text

PkgConfig = dict[str, Any]
LockData = dict[str, Any]
SourceConfig = dict[str, Any]

DIM: Final[str] = attr("dim")
GREEN: Final[str] = fg("green")
CYAN: Final[str] = fg("cyan")
YELLOW: Final[str] = fg("yellow")
RED: Final[str] = fg("red")
BOLD: Final[str] = attr("bold")
RESET: Final[str] = attr("reset")

PKG_JSON: Final[Path] = Path.home() / ".local" / "pack" / "pkg.json"
PKG_LOCK: Final[Path] = Path.home() / ".local" / "pack" / "pkg.lock"
PKG_SCHEMA: Final[Path] = Path.home() / ".local" / "pack" / "pkg.schema.json"
BUILD_LOG: Final[Path] = Path("/tmp/pack.build.log")

HTTP_TIMEOUT: Final[int] = 30
RESERVED_KEYS: Final[frozenset[str]] = frozenset({"$schema"})
CONSOLE: Final[Console] = Console()


class LockEntry(TypedDict, total=False):
    version: str
    artifact: str
    repo: str
    installed_at: str
    url: str


class ReleaseAsset(Protocol):  # pylint: disable=too-few-public-methods
    name: str
    browser_download_url: str


class ReleaseLike(Protocol):  # pylint: disable=too-few-public-methods
    tag_name: str
    tarball_url: str

    def get_assets(self) -> Iterable[ReleaseAsset]: ...


class PackageError(Exception):
    """Raised when a package operation fails in a recoverable way."""


@dataclass
class LogContext:
    """Thread-safe wrapper around a shared log file."""

    file: IO[str]
    lock: threading.Lock


@dataclass
class UpdateRequest:
    """Source-independent parameters forwarded from cmd_update to handlers."""

    log: IO[str]
    force: bool
    yes: bool
    filter_packages: list[str] | None


@dataclass
class ResolveResult:
    """Result of checking a single package for available updates."""

    name: str
    current_version: str
    latest_version: str
    needs_update: bool
    extra: dict[str, Any]
    error: str | None = None


@dataclass
class PackageTask:
    """Mutable per-package state displayed on the install dashboard."""

    name: str
    status: str
    detail: str = ""
    version: str = ""
    done_event: threading.Event = field(default_factory=threading.Event)
    spinner: Spinner = field(default_factory=lambda: Spinner("dots", style="cyan"))


@dataclass
class InstallJob:
    """Everything needed to install one package in a worker thread."""

    name: str
    pkg_config: PkgConfig
    resolved: ResolveResult
    task: PackageTask
    deps: list[PackageTask]


@dataclass
class InstallContext:
    """Shared mutable state for the parallel install phase."""

    source_name: str
    source_lock: dict[str, Any]
    full_lock: LockData
    lock_mutex: threading.Lock
    log_ctx: LogContext


class SourceHandler(Protocol):
    """Protocol that source backends implement for parallel updates."""

    def resolve(
        self,
        name: str,
        pkg_config: PkgConfig,
        current_version: str,
        force: bool,
    ) -> ResolveResult: ...

    def install(  # pylint: disable=too-many-arguments,too-many-positional-arguments
        self,
        name: str,
        pkg_config: PkgConfig,
        resolved: ResolveResult,
        task: PackageTask,
        log_ctx: LogContext,
    ) -> LockEntry: ...


def validate_config(config: PkgConfig) -> None:
    if not PKG_SCHEMA.exists():
        print(f"  {RED}[F]{RESET} {PKG_SCHEMA} not found", file=sys.stderr)
        sys.exit(1)
    with open(PKG_SCHEMA, encoding="utf-8") as f:
        schema: dict[str, Any] = json.load(f)
    try:
        jsonschema.validate(config, schema)
    except jsonschema.ValidationError as e:
        path: str = (
            "/".join(str(p) for p in e.absolute_path) if e.absolute_path else "(root)"
        )
        print(
            f"  {RED}[F]{RESET} pkg.json validation error at" f" '{path}': {e.message}",
            file=sys.stderr,
        )
        sys.exit(1)


def load_pkg_json() -> PkgConfig:
    if not PKG_JSON.exists():
        print(f"  {RED}[F]{RESET} {PKG_JSON} not found", file=sys.stderr)
        sys.exit(1)
    with open(PKG_JSON, encoding="utf-8") as f:
        config: PkgConfig = json.load(f)
    validate_config(config)
    return config


def load_pkg_lock() -> LockData:
    if PKG_LOCK.exists():
        with open(PKG_LOCK, encoding="utf-8") as f:
            return cast(LockData, json.load(f))
    return {}


def save_pkg_lock(lock: LockData) -> None:
    with open(PKG_LOCK, "w", encoding="utf-8") as f:
        json.dump(lock, f, indent=2)
        f.write("\n")


def get_sources(config: PkgConfig) -> dict[str, SourceConfig]:
    """Return source configs, filtering out reserved keys like $schema."""
    return {k: v for k, v in config.items() if k not in RESERVED_KEYS}


def topo_sort(
    targets: list[str],
    get_requires: Callable[[str], list[str]],
    all_names: set[str],
) -> list[str]:
    """Topological sort of targets using a get_requires callback.

    Automatically pulls in dependencies that exist in all_names.
    """
    target_set: set[str] = set(targets)

    queue: deque[str] = deque(targets)
    while queue:
        name: str = queue.popleft()
        for req in get_requires(name):
            if req not in target_set and req in all_names:
                target_set.add(req)
                queue.append(req)

    in_degree: dict[str, int] = {n: 0 for n in target_set}
    dependents: dict[str, list[str]] = {n: [] for n in target_set}

    for name in target_set:
        for req in get_requires(name):
            if req in target_set:
                in_degree[name] += 1
                dependents[req].append(name)

    ready: deque[str] = deque(n for n in targets if in_degree.get(n, 0) == 0)
    for n in target_set - set(targets):
        if in_degree[n] == 0:
            ready.append(n)

    ordered: list[str] = []
    while ready:
        node: str = ready.popleft()
        ordered.append(node)
        for dep in dependents[node]:
            in_degree[dep] -= 1
            if in_degree[dep] == 0:
                ready.append(dep)

    if len(ordered) != len(target_set):
        cycle: set[str] = target_set - set(ordered)
        raise RuntimeError(
            f"dependency cycle detected among: {', '.join(sorted(cycle))}"
        )

    return ordered


def sort_sources(sources: dict[str, SourceConfig]) -> list[str]:
    """Topo-sort source names based on source-level requires."""
    names: list[str] = list(sources.keys())
    all_names: set[str] = set(names)

    def get_req(name: str) -> list[str]:
        return cast(list[str], sources.get(name, {}).get("requires", []))

    return topo_sort(names, get_req, all_names)


def download_to(resp: requests.Response, dest: Path) -> None:
    with open(dest, "wb") as f:
        for chunk in resp.iter_content(chunk_size=8192):
            f.write(chunk)


def _expand_vars(raw_vars: dict[str, str]) -> dict[str, str]:
    """Expand ~ in _dir vars and ensure those directories exist."""
    expanded: dict[str, str] = {
        k: str(Path(v).expanduser()) if k.endswith("_dir") else v
        for k, v in raw_vars.items()
    }
    for k, v in expanded.items():
        if k.endswith("_dir"):
            Path(v).mkdir(parents=True, exist_ok=True)
    return expanded


def resolve_pkg_requires(
    requires: list[str], source_name: str
) -> list[tuple[str, str]]:
    """Parse requires list into (source, name) tuples.

    Bare names resolve to current source. Qualified 'source/name' are split.
    """

    def parse(req: str) -> tuple[str, str]:
        src: str
        _: str
        name: str
        src, _, name = req.partition("/")
        return (src, name) if name else (source_name, req)

    return [parse(r) for r in requires]


def get_github_client() -> Github:
    """Create an authenticated GitHub client.

    Tries GITHUB_TOKEN env var, then gh CLI, then falls back to
    unauthenticated.
    """
    token: str | None = os.environ.get("GITHUB_TOKEN")
    if token:
        return Github(auth=Auth.Token(token))

    try:
        result: subprocess.CompletedProcess[str] = subprocess.run(
            ["gh", "auth", "token"],
            capture_output=True,
            text=True,
            check=False,
        )
        if result.returncode == 0 and result.stdout.strip():
            return Github(auth=Auth.Token(result.stdout.strip()))
    except FileNotFoundError:
        pass

    return Github()


def get_auth_token(g: Github) -> str | None:
    raw_auth: object = getattr(g, "auth", None)
    if isinstance(raw_auth, Auth.Token):
        return raw_auth.token
    return None


@dataclass
class TagShim:
    """Minimal release-like wrapper around a Git tag (satisfies
    ReleaseLike)."""

    tag_name: str
    tarball_url: str

    @staticmethod
    def get_assets() -> list[ReleaseAsset]:
        return []

    @classmethod
    def from_tag(cls, tag: Any) -> TagShim:
        return cls(tag_name=tag.name, tarball_url=tag.tarball_url)


def get_latest_release(repo: Repository) -> ReleaseLike:
    """Return the latest release, falling back to the most recent by
    date."""
    try:
        return repo.get_latest_release()  # type: ignore[return-value]
    except UnknownObjectException:
        for release in repo.get_releases():
            if not release.draft and not release.prerelease:
                return release  # type: ignore[return-value]

    tags = repo.get_tags()
    if tags.totalCount:
        return TagShim.from_tag(tags[0])

    raise RuntimeError(f"no suitable release or tag found for {repo.full_name}")


def find_asset(assets: Iterable[ReleaseAsset], artifact: str) -> ReleaseAsset | None:
    return next((a for a in assets if a.name == artifact), None)


def resolve_artifact(
    latest: ReleaseLike,
    artifact: str | None,
    name: str,
    version: str,
) -> tuple[str, str]:
    """Resolve the download URL and artifact filename from a release."""
    if artifact is None:
        return latest.tarball_url, f"{name}-{version}.tar.gz"

    resolved: str = artifact.format(version=version)
    asset: ReleaseAsset | None = find_asset(latest.get_assets(), resolved)
    if not asset:
        raise PackageError(f"no artifact '{resolved}' found in release assets")
    return asset.browser_download_url, asset.name


class GithubSourceHandler:
    """SourceHandler implementation for GitHub releases."""

    def __init__(self, source_config: SourceConfig) -> None:
        self._client: Github = get_github_client()
        self._auth_token: str | None = get_auth_token(self._client)
        self._source_vars: dict[str, str] = _expand_vars(source_config.get("vars", {}))

    def resolve(
        self,
        name: str,
        pkg_config: PkgConfig,
        current_version: str,
        force: bool,
    ) -> ResolveResult:
        try:
            repo: Repository = self._client.get_repo(pkg_config["repo"])
            release: ReleaseLike = get_latest_release(repo)
            latest_version: str = release.tag_name.removeprefix("v")
            return ResolveResult(
                name=name,
                current_version=current_version,
                latest_version=latest_version,
                needs_update=force or current_version != latest_version,
                extra={
                    "release": release,
                    "repo": pkg_config["repo"],
                },
            )
        except (RuntimeError, PackageError) as e:
            return ResolveResult(
                name=name,
                current_version=current_version,
                latest_version="",
                needs_update=False,
                extra={},
                error=str(e),
            )

    def _download(self, url: str, dest: Path, task: PackageTask) -> None:
        task.status = "downloading"
        task.detail = dest.name
        headers: dict[str, str] = {}
        if self._auth_token:
            headers["Authorization"] = f"token {self._auth_token}"
        resp: requests.Response = requests.get(
            url, stream=True, headers=headers, timeout=HTTP_TIMEOUT
        )
        resp.raise_for_status()
        download_to(resp, dest)

    def install(  # pylint: disable=too-many-arguments,too-many-positional-arguments
        self,
        name: str,
        pkg_config: PkgConfig,
        resolved: ResolveResult,
        task: PackageTask,
        log_ctx: LogContext,
    ) -> LockEntry:
        download_url: str
        artifact_name: str
        download_url, artifact_name = resolve_artifact(
            resolved.extra["release"],
            pkg_config.get("artifact"),
            name,
            resolved.latest_version,
        )

        base_vars: dict[str, str] = {
            **self._source_vars,
            "version": resolved.latest_version,
        }

        pre_cmds: list[str] | None = pkg_config.get("pre")
        if pre_cmds:
            task.detail = "running pre commands..."
            with tempfile.TemporaryDirectory(prefix=f"pack_{name}_pre_") as d:
                _run_build_cmds_captured(pre_cmds, base_vars, d, task, log_ctx)

        with tempfile.TemporaryDirectory(prefix=f"pack_{name}_") as tmpdir:
            artifact_path: Path = Path(tmpdir) / artifact_name
            self._download(download_url, artifact_path, task)

            task.status = "building"
            with log_ctx.lock:
                log_ctx.file.write(f"=== {name} ({pkg_config['repo']}) ===\n")
            _run_build_cmds_captured(
                pkg_config["cmds"],
                {**base_vars, "artifact": str(artifact_path), "tmpdir": tmpdir},
                tmpdir,
                task,
                log_ctx,
            )

        return LockEntry(
            version=resolved.latest_version,
            artifact=artifact_name,
            repo=pkg_config["repo"],
            installed_at=datetime.now(timezone.utc).isoformat(),
            url=download_url,
        )


def _run_build_cmds_captured(
    cmds: list[str],
    variables: dict[str, str],
    cwd: str,
    task: PackageTask,
    log_ctx: LogContext,
) -> None:
    """Run build commands, updating *task* for the dashboard."""
    for i, cmd in enumerate(cmds, 1):
        expanded: str = cmd.format(**variables)
        task.detail = f"[{i}/{len(cmds)}] {expanded}"

        with log_ctx.lock:
            log_ctx.file.write(f"$ {expanded}\n")

        with subprocess.Popen(
            expanded,
            shell=True,
            cwd=cwd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
        ) as proc:
            assert proc.stdout is not None
            for line in proc.stdout:
                raw: str = line.rstrip("\n")
                task.detail = f"[{i}/{len(cmds)}] {raw}"
                with log_ctx.lock:
                    log_ctx.file.write(line)

            returncode: int = proc.wait()

        with log_ctx.lock:
            log_ctx.file.write(f"exit {returncode}\n\n")
            log_ctx.file.flush()

        if returncode != 0:
            raise RuntimeError(f"command failed (exit {returncode}): {expanded}")


def _resolve_phase(
    handler: SourceHandler,
    packages: dict[str, PkgConfig],
    targets: list[str],
    source_lock: dict[str, Any],
    force: bool,
) -> list[ResolveResult]:
    """Phase 1: check all packages for updates in parallel."""
    results: list[ResolveResult] = []

    with CONSOLE.status("[cyan]checking for updates...[/cyan]"):
        with concurrent.futures.ThreadPoolExecutor(max_workers=len(targets)) as pool:
            futures: dict[concurrent.futures.Future[ResolveResult], str] = {
                pool.submit(
                    handler.resolve,
                    name,
                    packages[name],
                    source_lock.get(name, {}).get("version", "none"),
                    force,
                ): name
                for name in targets
            }
            for future in concurrent.futures.as_completed(futures):
                results.append(future.result())

    order: dict[str, int] = {name: i for i, name in enumerate(targets)}
    results.sort(key=lambda r: order.get(r.name, 0))
    return results


def _print_update_summary(
    to_update: list[ResolveResult],
    up_to_date: list[ResolveResult],
    errors: list[ResolveResult],
) -> None:
    """Phase 2: print apt-style summary of available updates."""
    if to_update:
        max_name: int = max(len(r.name) for r in to_update)
        print(f"{BOLD}The following packages will be updated:{RESET}")
        for r in to_update:
            print(
                f"  {CYAN}{r.name:<{max_name}}{RESET}"
                f"  {r.current_version}"
                f" {YELLOW}->{RESET} {r.latest_version}"
            )

    if up_to_date:
        names: str = ", ".join(
            f"{r.name} {DIM}{r.current_version}{RESET}" for r in up_to_date
        )
        print(f"{BOLD}Up to date:{RESET} {names}")

    if errors:
        print(f"{BOLD}{RED}Errors:{RESET}")
        for r in errors:
            print(f"  {RED}{r.name}{RESET}: {r.error}")


def _build_dashboard(tasks: list[PackageTask], max_name: int) -> Table:
    """Build a rich Table showing current install progress."""
    table: Table = Table.grid(padding=(0, 1))
    for task in tasks:
        icon: Text | Spinner
        if task.status in ("downloading", "building"):
            icon = task.spinner
        elif task.status == "done":
            icon = Text("✓", style="green")
        elif task.status == "failed":
            icon = Text("✗", style="red")
        else:
            icon = Text("◌", style="dim")

        name_style: str = "bold" if task.status in ("downloading", "building") else ""
        detail_style: str = "red" if task.status == "failed" else "dim"
        table.add_row(
            icon,
            Text(f" {task.name:<{max_name}} ", style=name_style),
            Text(
                task.detail,
                style=detail_style,
                overflow="ellipsis",
                no_wrap=True,
            ),
        )
    return table


def _build_install_jobs(
    packages: dict[str, PkgConfig],
    to_update: list[ResolveResult],
    tasks: dict[str, PackageTask],
    source_name: str,
) -> list[InstallJob]:
    """Create InstallJob list with dependency info for each package."""
    update_names: set[str] = set(tasks.keys())
    jobs: list[InstallJob] = []
    for r in to_update:
        requires: list[str] = packages[r.name].get("requires", [])
        dep_tasks: list[PackageTask] = [
            tasks[dep_name]
            for src, dep_name in resolve_pkg_requires(requires, source_name)
            if src == source_name and dep_name in update_names
        ]
        jobs.append(
            InstallJob(
                name=r.name,
                pkg_config=packages[r.name],
                resolved=r,
                task=tasks[r.name],
                deps=dep_tasks,
            )
        )
    return jobs


def _install_worker(
    handler: SourceHandler,
    job: InstallJob,
    ictx: InstallContext,
) -> None:
    """Phase 3 worker: install a single package in a thread."""
    task: PackageTask = job.task
    try:
        for dep in job.deps:
            dep.done_event.wait()
            if dep.status == "failed":
                raise PackageError(f"dependency {dep.name} failed")

        entry: LockEntry = handler.install(
            job.name,
            job.pkg_config,
            job.resolved,
            task,
            ictx.log_ctx,
        )

        with ictx.lock_mutex:
            ictx.source_lock[job.name] = entry

        task.status = "done"
        task.detail = f"v{job.resolved.latest_version}"
        task.version = job.resolved.latest_version
    except (
        PackageError,
        RuntimeError,
        OSError,
        requests.RequestException,
    ) as e:
        task.status = "failed"
        task.detail = str(e)
    finally:
        task.done_event.set()


def _install_phase(
    handler: SourceHandler,
    packages: dict[str, PkgConfig],
    to_update: list[ResolveResult],
    ictx: InstallContext,
) -> None:
    """Phase 3: download and build packages in parallel with a live
    dashboard."""
    tasks: dict[str, PackageTask] = {
        r.name: PackageTask(name=r.name, status="pending", detail="waiting...")
        for r in to_update
    }
    task_list: list[PackageTask] = [tasks[r.name] for r in to_update]
    max_name: int = max(len(t.name) for t in task_list)
    jobs: list[InstallJob] = _build_install_jobs(
        packages, to_update, tasks, ictx.source_name
    )

    with Live(
        _build_dashboard(task_list, max_name),
        refresh_per_second=10,
        console=CONSOLE,
    ) as live:
        with concurrent.futures.ThreadPoolExecutor(
            max_workers=max(1, len(jobs))
        ) as pool:
            futures: list[concurrent.futures.Future[None]] = [
                pool.submit(_install_worker, handler, job, ictx) for job in jobs
            ]
            pending: set[concurrent.futures.Future[None]] = set(futures)
            while pending:
                _done, pending = concurrent.futures.wait(pending, timeout=0.2)
                live.update(_build_dashboard(task_list, max_name))

    succeeded: int = sum(1 for t in task_list if t.status == "done")
    failed: int = sum(1 for t in task_list if t.status == "failed")
    if failed:
        print(f"{succeeded} installed, {RED}{failed} failed{RESET}")
        print(f"{DIM}full log: {BUILD_LOG}{RESET}")
    else:
        print(f"{GREEN}{succeeded} installed{RESET}")


def _run_parallel_update(
    source_name: str,
    handler: SourceHandler,
    source_config: SourceConfig,
    lock: LockData,
    req: UpdateRequest,
) -> None:
    """Orchestrate three-phase parallel update for one source."""
    packages: dict[str, PkgConfig] = source_config.get("packages", {})
    if not isinstance(packages, dict):
        return

    if req.filter_packages is not None:
        targets: list[str] = [p for p in req.filter_packages if p in packages]
    else:
        targets = list(packages.keys())

    if not targets:
        return

    def get_pkg_requires(name: str) -> list[str]:
        """Extract same-source deps for topo-sort expansion."""
        return [
            r if "/" not in r else r.split("/", 1)[1]
            for r in packages.get(name, {}).get("requires", [])
            if "/" not in r or r.startswith(f"{source_name}/")
        ]

    targets = topo_sort(targets, get_pkg_requires, set(packages.keys()))
    source_lock: dict[str, Any] = lock.setdefault(source_name, {})

    results: list[ResolveResult] = _resolve_phase(
        handler, packages, targets, source_lock, req.force
    )

    to_update: list[ResolveResult] = [
        r for r in results if r.needs_update and r.error is None
    ]
    up_to_date: list[ResolveResult] = [
        r for r in results if not r.needs_update and r.error is None
    ]
    errors: list[ResolveResult] = [r for r in results if r.error is not None]

    _print_update_summary(to_update, up_to_date, errors)

    if not to_update:
        return

    if not req.yes:
        answer: str = input(f"{len(to_update)} to update. Proceed? [Y/n] ")
        if answer.strip().lower() == "n":
            print(f"{DIM}aborted{RESET}")
            return

    ictx: InstallContext = InstallContext(
        source_name=source_name,
        source_lock=source_lock,
        full_lock=lock,
        lock_mutex=threading.Lock(),
        log_ctx=LogContext(file=req.log, lock=threading.Lock()),
    )
    _install_phase(handler, packages, to_update, ictx)


def _get_source_handler(
    source_name: str, source_config: SourceConfig
) -> SourceHandler | None:
    """Create the appropriate SourceHandler for a given source name."""
    if source_name == "github":
        return GithubSourceHandler(source_config)
    return None


def cmd_update(args: argparse.Namespace, config: PkgConfig) -> None:
    lock: LockData = load_pkg_lock()
    sources: dict[str, SourceConfig] = get_sources(config)
    filter_packages: list[str] | None = args.packages if args.packages else None
    ordered_sources: list[str] = sort_sources(sources)

    with open(BUILD_LOG, "w", encoding="utf-8") as log:
        req: UpdateRequest = UpdateRequest(
            log=log,
            force=args.force,
            yes=args.yes,
            filter_packages=filter_packages,
        )
        for source_name in ordered_sources:
            handler: SourceHandler | None = _get_source_handler(
                source_name, sources[source_name]
            )
            if handler is None:
                print(
                    f"{DIM}skipping unknown source: {source_name}{RESET}",
                    file=sys.stderr,
                )
                continue

            print(f"{BOLD}{YELLOW}:: {source_name}{RESET}")
            _run_parallel_update(
                source_name,
                handler,
                sources[source_name],
                lock,
                req,
            )

    save_pkg_lock(lock)


def print_pkg_info(name: str, source_lock: dict[str, Any]) -> None:
    """Print installed version or 'not installed' for a single package."""
    if name in source_lock:
        info: dict[str, Any] = source_lock[name]
        version: str = info.get("version", "?")
        ts: str = info.get("installed_at", "")
        suffix: str = f" {DIM}(installed {ts}){RESET}" if ts else ""
        print(f"{CYAN}{name}{RESET}: {GREEN}v{version}{RESET}{suffix}")
    else:
        print(f"{CYAN}{name}{RESET}: {DIM}not installed{RESET}")


def cmd_list(config: PkgConfig) -> None:
    lock: LockData = load_pkg_lock()
    sources: dict[str, SourceConfig] = get_sources(config)

    for source_name, source_config in sources.items():
        packages: dict[str, Any] | list[str] = source_config.get("packages", {})
        if not packages:
            continue

        print(f"{BOLD}{YELLOW}:: {source_name}{RESET}")
        source_lock: dict[str, Any] = lock.get(source_name, {})
        names: list[str] = (
            list(packages.keys()) if isinstance(packages, dict) else packages
        )

        for name in names:
            print_pkg_info(name, source_lock)


def _print_status_results(results: list[ResolveResult]) -> None:
    """Print resolve results in the status format."""
    for r in results:
        if r.error:
            print(
                f"{RED}[F]{RESET} {r.name}: {r.current_version}"
                f" {DIM}(error: {r.error}){RESET}"
            )
        elif r.needs_update:
            print(
                f"{YELLOW}[NEW]{RESET} {BOLD}{r.name}{RESET}:"
                f" {r.current_version}"
                f" {YELLOW}->{RESET} {r.latest_version}"
            )
        else:
            print(
                f"{GREEN}[OK]{RESET} {r.name}: {GREEN}{r.current_version}{RESET}"
            )


def cmd_status(config: PkgConfig) -> None:
    lock: LockData = load_pkg_lock()
    sources: dict[str, SourceConfig] = get_sources(config)

    for source_name, source_config in sources.items():
        packages: dict[str, Any] | list[str] = source_config.get("packages", {})
        if not packages:
            continue

        print(f"{BOLD}{YELLOW}:: {source_name}{RESET}")
        source_lock: dict[str, Any] = lock.get(source_name, {})

        handler: SourceHandler | None = _get_source_handler(source_name, source_config)
        if handler and isinstance(packages, dict):
            results: list[ResolveResult] = _resolve_phase(
                handler,
                packages,
                list(packages.keys()),
                source_lock,
                force=False,
            )
            _print_status_results(results)
        else:
            names_list: list[str] = (
                list(packages.keys()) if isinstance(packages, dict) else packages
            )
            for name in names_list:
                print_pkg_info(name, source_lock)


def main() -> None:
    parser = argparse.ArgumentParser(
        description=(
            "Meta package manager -- update packages from" " multiple sources"
        ),
        epilog="""\
package config (~/pkg.json):
  top-level keys are source names (github, cargo, apt, ...).
  each source has:
    packages      package definitions (object for github, array for simple sources)
    vars          variables injected into cmds/pre templates (e.g. install_dir)
    requires      array of source names that must finish before this source

  github package fields:
    repo          GitHub owner/repo (required)
    cmds          shell commands to run after downloading (required)
    artifact      release asset name (omit for source tarball, supports {version})
    requires      package deps (bare name = same source, source/name = cross-source)
    pre           shell commands to run before download

  template variables for cmds: {artifact} {install_dir} {version} {tmpdir} + vars
  template variables for pre:  {install_dir} {version} + vars

examples:
  pack                      update all packages from all sources
  pack update nvim tmux     update specific packages
  pack update -f nvim       force re-download even if up to date
  pack update -y            update all without prompts
  pack status               check which packages have updates available
  pack list                 show installed versions from the lockfile""",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub: argparse._SubParsersAction[argparse.ArgumentParser] = parser.add_subparsers(
        dest="command"
    )

    p_update: argparse.ArgumentParser = sub.add_parser(
        "update", help="download and install latest releases"
    )
    p_update.add_argument(
        "packages",
        nargs="*",
        help="packages to update (default: all)",
    )
    p_update.add_argument(
        "-f",
        "--force",
        action="store_true",
        help="re-download even if already up to date",
    )
    p_update.add_argument(
        "-y",
        "--yes",
        action="store_true",
        help="skip confirmation prompts",
    )

    sub.add_parser(
        "list",
        help="show installed packages and versions from ~/pkg.lock",
    )
    sub.add_parser(
        "status",
        help="check for available updates without installing",
    )

    args: argparse.Namespace = parser.parse_args()
    config: PkgConfig = load_pkg_json()

    if args.command == "update" or args.command is None:
        if args.command is None:
            args.packages = []
            args.force = False
            args.yes = False
        cmd_update(args, config)
    elif args.command == "list":
        cmd_list(config)
    elif args.command == "status":
        cmd_status(config)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print(f"\n{DIM}aborted{RESET}")
        sys.exit(130)
    except (
        PackageError,
        RuntimeError,
        OSError,
        requests.RequestException,
    ) as e:
        print(f"{RED}[F]{RESET} {e}", file=sys.stderr)
        sys.exit(1)
